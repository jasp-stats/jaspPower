msgid "sample sizes of %1$s in each group"
msgstr "各組樣本數皆為 %1$s"

msgid "group sample sizes of %1$s and %2$s, respectively"
msgstr "組別樣本數分別為 %1$s 與 %2$s"

msgid "sample sizes of at least %1$s in each group"
msgstr "各組樣本數至少為 %1$s"

msgid "group sample sizes of at least %1$s and %2$s, respectively"
msgstr "組別樣本數分別至少為 %1$s 與 %2$s"

msgid ""
"On the other hand, if %1$s%2$s, the evidence would exceed the criterion "
"&mdash; and hence we would correctly claim that %3$s &mdash; at least %4$s%% "
